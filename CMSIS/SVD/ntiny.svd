<?xml version="1.0" encoding="UTF-8"?>
<!--
    ntiny.svd
    System View Description for the NTiny RISC-V SoC.

    Auto-importable by Keil uVision, IAR, OpenOCD, J-Link, gdb (with
    pyOCD/svd2gdb), Eclipse CDT (Peripherals view), STM32CubeIDE / SES,
    VS Code Cortex-Debug, etc.

    SPDX-License-Identifier: Apache-2.0
-->
<device schemaVersion="1.3"
        xmlns:xs="http://www.w3.org/2001/XMLSchema-instance"
        xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">

  <!-- ====================== Device metadata ============================ -->
  <vendor>NTiny</vendor>
  <vendorID>NT</vendorID>
  <name>NTINY</name>
  <series>NTiny RISC-V</series>
  <version>1.0</version>
  <description>NTiny is a 4-stage in-order RV32IMAFC RISC-V SoC with
               GPIO, UART, SPI, I2C, Timer, PWM, CRC, CLINT and PLIC
               peripherals.</description>
  <licenseText>Apache-2.0</licenseText>

  <!-- ============================ CPU ================================== -->
  <cpu>
    <name>other</name>
    <revision>r0p0</revision>
    <endian>little</endian>
    <mpuPresent>false</mpuPresent>
    <fpuPresent>true</fpuPresent>
    <fpuDP>false</fpuDP>
    <icachePresent>false</icachePresent>
    <dcachePresent>false</dcachePresent>
    <itcmPresent>false</itcmPresent>
    <dtcmPresent>false</dtcmPresent>
    <nvicPrioBits>2</nvicPrioBits>
    <vendorSystickConfig>false</vendorSystickConfig>
  </cpu>

  <!-- ====================== Memory addressing ========================== -->
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>

  <!-- Default register attributes for the whole device. -->
  <size>32</size>
  <access>read-write</access>
  <resetValue>0x00000000</resetValue>
  <resetMask>0xFFFFFFFF</resetMask>

  <peripherals>

    <!-- ============================== GPIO ============================= -->
    <peripheral>
      <name>GPIO</name>
      <description>General-Purpose I/O</description>
      <groupName>GPIO</groupName>
      <baseAddress>0x10030000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>GPIO_IRQ</name>
        <description>GPIO interrupt (PLIC source 3)</description>
        <value>3</value>
      </interrupt>
      <registers>
        <register>
          <name>DDR</name>
          <description>Data Direction Register (1 = output)</description>
          <addressOffset>0x00</addressOffset>
          <access>read-write</access>
        </register>
        <register>
          <name>DOUT</name>
          <description>Data Output Register</description>
          <addressOffset>0x04</addressOffset>
          <access>read-write</access>
        </register>
        <register>
          <name>DIN</name>
          <description>Data Input Register</description>
          <addressOffset>0x08</addressOffset>
          <access>read-only</access>
        </register>
        <register>
          <name>CMD</name>
          <description>Command Register (reset / IRQ-enable strobes)</description>
          <addressOffset>0x0C</addressOffset>
          <access>write-only</access>
          <fields>
            <field><name>RST_DOUT</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>RST_DDR</name> <bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>RST_ALL</name> <bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>IRQ_EN</name>  <bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
      </registers>
    </peripheral>

    <!-- ============================== UART ============================= -->
    <peripheral>
      <name>UART</name>
      <description>Universal Asynchronous Receiver/Transmitter</description>
      <groupName>UART</groupName>
      <baseAddress>0x10000000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>UART_IRQ</name>
        <description>UART interrupt (PLIC source 0)</description>
        <value>0</value>
      </interrupt>
      <registers>
        <register>
          <name>RX</name>
          <description>Receive Data</description>
          <addressOffset>0x00</addressOffset>
          <access>read-only</access>
          <fields>
            <field><name>DATA</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
          </fields>
        </register>
        <register>
          <name>TX</name>
          <description>Transmit Data</description>
          <addressOffset>0x04</addressOffset>
          <access>write-only</access>
          <fields>
            <field><name>DATA</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>Status Flags</description>
          <addressOffset>0x08</addressOffset>
          <access>read-only</access>
          <fields>
            <field><name>RXVALID</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth>
              <description>RX FIFO has at least one byte</description></field>
            <field><name>RXFULL </name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>TXEMPTY</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>TXFULL </name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>IE     </name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register>
          <name>CONTROL</name>
          <description>Control Register</description>
          <addressOffset>0x0C</addressOffset>
          <access>read-write</access>
          <fields>
            <field><name>RST_TX</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>RST_RX</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>IE    </name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register>
          <name>BAUDRATE</name>
          <description>Baud divisor: (F_CPU / baud) - 1</description>
          <addressOffset>0x10</addressOffset>
          <access>read-write</access>
        </register>
      </registers>
    </peripheral>

    <!-- ============================== SPI ============================== -->
    <peripheral>
      <name>SPI</name>
      <description>Serial Peripheral Interface (master)</description>
      <groupName>SPI</groupName>
      <baseAddress>0x10010000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>SPI_IRQ</name>
        <description>SPI interrupt (PLIC source 1)</description>
        <value>1</value>
      </interrupt>
      <registers>
        <register><name>DGIER</name><description>Global Interrupt Enable</description><addressOffset>0x1C</addressOffset>
          <fields><field><name>GIE</name><bitOffset>31</bitOffset><bitWidth>1</bitWidth></field></fields></register>
        <register><name>IPISR</name><description>IP Interrupt Status</description><addressOffset>0x20</addressOffset>
          <fields><field><name>TX_EMPTY</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field></fields></register>
        <register><name>IPIER</name><description>IP Interrupt Enable</description><addressOffset>0x28</addressOffset>
          <fields><field><name>TX_EMPTY</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field></fields></register>
        <register><name>SRR</name>  <description>Soft Reset Register (write 0x0A to reset)</description><addressOffset>0x40</addressOffset><access>write-only</access></register>
        <register><name>CR</name>   <description>Control Register</description><addressOffset>0x60</addressOffset>
          <fields>
            <field><name>LOOP        </name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>SPE         </name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>MASTER      </name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>CPOL        </name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>CPHA        </name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>TXFIFO_RST  </name><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>RXFIFO_RST  </name><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>MANUAL_SS   </name><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>TRANS_INHIBIT</name><bitOffset>8</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>LSB_FIRST   </name><bitOffset>9</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register><name>SR</name>   <description>Status Register</description><addressOffset>0x64</addressOffset><access>read-only</access>
          <fields>
            <field><name>RX_EMPTY</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>RX_FULL </name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>TX_EMPTY</name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>TX_FULL </name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register><name>DTR</name>  <description>Data Transmit Register</description><addressOffset>0x68</addressOffset><access>write-only</access>
          <fields><field><name>DATA</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field></fields></register>
        <register><name>DRR</name>  <description>Data Receive Register</description><addressOffset>0x6C</addressOffset><access>read-only</access>
          <fields><field><name>DATA</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field></fields></register>
        <register><name>SSR</name>  <description>Slave Select Register (active-low)</description><addressOffset>0x70</addressOffset>
          <fields><field><name>VALUE</name><bitOffset>0</bitOffset><bitWidth>8</bitWidth></field></fields></register>
        <register><name>CLK_RATIO</name><description>Clock Ratio Divider</description><addressOffset>0x74</addressOffset></register>
      </registers>
    </peripheral>

    <!-- ============================== I2C ============================== -->
    <peripheral>
      <name>I2C</name>
      <description>Inter-Integrated Circuit (master)</description>
      <groupName>I2C</groupName>
      <baseAddress>0x10020000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>I2C_IRQ</name>
        <description>I2C interrupt (PLIC source 2)</description>
        <value>2</value>
      </interrupt>
      <registers>
        <register><name>CLK_PRESCALER</name><description>Clock divider</description><addressOffset>0x00</addressOffset></register>
        <register><name>CTRL</name>         <description>Control: [7]i2c_en [6]irq_en</description><addressOffset>0x04</addressOffset>
          <fields>
            <field><name>IRQ_EN</name><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>I2C_EN</name><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register><name>RX</name>           <description>Received byte</description><addressOffset>0x08</addressOffset><access>read-only</access></register>
        <register><name>STATUS</name>       <description>Status flags</description><addressOffset>0x0C</addressOffset><access>read-only</access>
          <fields>
            <field><name>IRQ_FLAG  </name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>TIP       </name><bitOffset>1</bitOffset><bitWidth>1</bitWidth>
              <description>Transfer in progress</description></field>
            <field><name>ARB_LOST  </name><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>BUSY      </name><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>RX_ACK    </name><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register><name>TX</name>           <description>Byte to transmit</description><addressOffset>0x10</addressOffset><access>write-only</access></register>
        <register><name>CMD</name>          <description>Command word (start/stop/r/w/ack/irq_ack)</description><addressOffset>0x14</addressOffset><access>write-only</access>
          <fields>
            <field><name>IRQ_ACK</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>ACK    </name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>WRITE  </name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>READ   </name><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>STOP   </name><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>START  </name><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
      </registers>
    </peripheral>

    <!-- ============================ TIMER ============================== -->
    <peripheral>
      <name>TIMER</name>
      <description>Programmable Timer with Compare</description>
      <groupName>TIMER</groupName>
      <baseAddress>0x10050000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>CLOCK_PRESCALER</name>
          <description>Prescaler value (clock divider - 1)</description>
          <addressOffset>0x00</addressOffset>
        </register>
        <register>
          <name>COUNT</name>
          <description>Current counter value</description>
          <addressOffset>0x04</addressOffset>
        </register>
        <register>
          <name>CONTROL</name>
          <description>Control [6'b0, en, 1'b0]</description>
          <addressOffset>0x08</addressOffset>
          <fields>
            <field><name>ENABLE</name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register>
          <name>STATUS</name>
          <description>Status [7'b0, count_complete]</description>
          <addressOffset>0x0C</addressOffset>
          <access>read-only</access>
          <fields>
            <field><name>COMPLETE</name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register>
          <name>COMPARE</name>
          <description>Compare value -- match raises STATUS.COMPLETE</description>
          <addressOffset>0x10</addressOffset>
        </register>
      </registers>
    </peripheral>

    <!-- ============================== PWM ============================== -->
    <peripheral>
      <name>PWM</name>
      <description>Dual-channel PWM with dead-time generator</description>
      <groupName>PWM</groupName>
      <baseAddress>0x10040000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>PWM_IRQ</name>
        <description>PWM interrupt (PLIC source 4)</description>
        <value>4</value>
      </interrupt>
      <registers>
        <register><name>PRESCALER</name><addressOffset>0x00</addressOffset></register>
        <register>
          <name>CONTROL</name>
          <addressOffset>0x04</addressOffset>
          <fields>
            <field><name>PWM1_EN     </name><bitOffset>0</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>PWM2_EN     </name><bitOffset>1</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>COM_RE1     </name><bitOffset>2</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>COM_RE2     </name><bitOffset>3</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>CENTER_EDGE1</name><bitOffset>4</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>CENTER_EDGE2</name><bitOffset>5</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>INVERTING1  </name><bitOffset>6</bitOffset><bitWidth>1</bitWidth></field>
            <field><name>INVERTING2  </name><bitOffset>7</bitOffset><bitWidth>1</bitWidth></field>
          </fields>
        </register>
        <register><name>PERIOD1  </name><addressOffset>0x08</addressOffset></register>
        <register><name>PERIOD2  </name><addressOffset>0x0C</addressOffset></register>
        <register><name>COMPARE1 </name><addressOffset>0x10</addressOffset></register>
        <register><name>COMPARE2 </name><addressOffset>0x14</addressOffset></register>
        <register><name>DEADTIME1</name><addressOffset>0x18</addressOffset></register>
        <register><name>DEADTIME2</name><addressOffset>0x1C</addressOffset></register>
      </registers>
    </peripheral>

    <!-- ============================== PLIC ============================= -->
    <peripheral>
      <name>PLIC</name>
      <description>Platform-Level Interrupt Controller</description>
      <groupName>PLIC</groupName>
      <baseAddress>0x0C000000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x1000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>IE_INTERRUPT</name>
          <description>Per-source enable mask (bit per IRQ ID)</description>
          <addressOffset>0x00</addressOffset>
        </register>
        <register>
          <name>THRESHOLD</name>
          <description>Priority threshold (sources above threshold fire)</description>
          <addressOffset>0x04</addressOffset>
        </register>
        <register>
          <name>PRIORITY</name>
          <description>Per-source priority encoding</description>
          <addressOffset>0x08</addressOffset>
        </register>
        <register>
          <name>INTERRUPT_ID</name>
          <description>Read claims highest-priority pending IRQ</description>
          <addressOffset>0x0C</addressOffset>
          <access>read-only</access>
        </register>
      </registers>
    </peripheral>

    <!-- ============================== CLINT ============================ -->
    <peripheral>
      <name>CLINT</name>
      <description>Core-Local Interruptor (RISC-V SiFive layout)</description>
      <groupName>CLINT</groupName>
      <baseAddress>0x02000000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x10000</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>MSIP</name>
          <description>Machine-mode software interrupt pending</description>
          <addressOffset>0x0000</addressOffset>
        </register>
        <register>
          <name>MTIMECMP</name>
          <description>Lower 32 bits of mtimecmp</description>
          <addressOffset>0x4000</addressOffset>
        </register>
        <register>
          <name>MTIMECMPH</name>
          <description>Upper 32 bits of mtimecmp</description>
          <addressOffset>0x4004</addressOffset>
        </register>
        <register>
          <name>MTIME</name>
          <description>Lower 32 bits of free-running mtime</description>
          <addressOffset>0xBFF8</addressOffset>
          <access>read-only</access>
        </register>
        <register>
          <name>MTIMEH</name>
          <description>Upper 32 bits of free-running mtime</description>
          <addressOffset>0xBFFC</addressOffset>
          <access>read-only</access>
        </register>
      </registers>
    </peripheral>

  </peripherals>
</device>
